[paths]
; ffmpeg on PATH, or full path to ffmpeg.exe
ffmpeg=ffmpeg.exe
outdir=%USERPROFILE%\Pictures\Screenshots\webpcap CAPS
; MP4 display + canvas recordings
viddir=%USERPROFILE%\Videos\webpcap REC

[encode]
quality=90
lossless=0

[video]
fps=30
crf=23
port=19787
; display/window/region REC: system = speakers loopback into same MP4; off = silent
audio=system
; A/V fine-tune after auto start-offset (ms). Positive = delay audio (sound later); negative = advance audio
audio_delay_ms=0

[hotkeys]
remap=1
